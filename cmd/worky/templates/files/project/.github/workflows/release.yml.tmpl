name: Release

on:
  push:
    tags:
      - 'v*'

jobs:
  release:
    runs-on: ubuntu-latest
    permissions:
      contents: write
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-go@v5
        with:
          go-version: '1.24'

      - name: Install Hugo (extended)
        run: |
          wget -O hugo.deb https://github.com/gohugoio/hugo/releases/download/v0.145.0/hugo_extended_0.145.0_linux-amd64.deb
          sudo dpkg -i hugo.deb

      - name: Build site
        run: |
          hugo mod get github.com/davideimola/worky
          hugo mod get github.com/geekdocs/geekdoc
          hugo

      - name: Cross-compile
        run: |
          GOOS=linux  GOARCH=amd64 go build -o bin/<% .Slug %>-linux-amd64 .
          GOOS=darwin GOARCH=arm64 go build -o bin/<% .Slug %>-darwin-arm64 .
          GOOS=darwin GOARCH=amd64 go build -o bin/<% .Slug %>-darwin-amd64 .
          GOOS=windows GOARCH=amd64 go build -o bin/<% .Slug %>-windows-amd64.exe .

      - name: Create GitHub Release
        uses: softprops/action-gh-release@v2
        with:
          files: bin/*
