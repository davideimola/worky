---
const GH_URL = 'https://github.com/davideimola/worky';
const year = new Date().getFullYear();

const links = [
  { label: 'Getting Started', href: '/docs/getting-started/' },
  { label: 'CLI Reference', href: '/docs/cli/' },
  { label: 'GitHub', href: GH_URL },
  { label: 'Releases', href: `${GH_URL}/releases` },
];
---
<footer class="footer">
  <div class="container">
    <div class="footer-inner">
      <div class="footer-brand">
        <div class="footer-logo">
          <img src="/logo.svg" alt="Worky" height="20" style="display:block;opacity:0.85;" />
        </div>
        <p class="footer-tagline">Build interactive workshops in Go.<br/>Distribute as a single binary.</p>
      </div>

      <nav class="footer-nav">
        {links.map(l => (
          <a href={l.href} class="footer-link">{l.label}</a>
        ))}
      </nav>
    </div>

    <div class="footer-bottom">
      <span class="footer-copy">© {year} Davide Imola. Apache 2.0.</span>
      <span class="footer-made">
        Made with
        <svg id="footerHeart" viewBox="0 0 27 23" width="13" height="11" fill="#00C2A0" style="display:inline-block;vertical-align:middle;margin:0 2px;" aria-hidden="true">
          <rect x="4"  y="0"  width="3" height="3"/>
          <rect x="20" y="0"  width="3" height="3"/>
          <rect x="0"  y="4"  width="3" height="3"/>
          <rect x="4"  y="4"  width="3" height="3"/>
          <rect x="8"  y="4"  width="3" height="3"/>
          <rect x="16" y="4"  width="3" height="3"/>
          <rect x="20" y="4"  width="3" height="3"/>
          <rect x="24" y="4"  width="3" height="3"/>
          <rect x="0"  y="8"  width="3" height="3"/>
          <rect x="4"  y="8"  width="3" height="3"/>
          <rect x="8"  y="8"  width="3" height="3"/>
          <rect x="12" y="8"  width="3" height="3"/>
          <rect x="16" y="8"  width="3" height="3"/>
          <rect x="20" y="8"  width="3" height="3"/>
          <rect x="24" y="8"  width="3" height="3"/>
          <rect x="4"  y="12" width="3" height="3"/>
          <rect x="8"  y="12" width="3" height="3"/>
          <rect x="12" y="12" width="3" height="3"/>
          <rect x="16" y="12" width="3" height="3"/>
          <rect x="20" y="12" width="3" height="3"/>
          <rect x="8"  y="16" width="3" height="3"/>
          <rect x="12" y="16" width="3" height="3"/>
          <rect x="16" y="16" width="3" height="3"/>
          <rect x="12" y="20" width="3" height="3"/>
        </svg>
        and Go
      </span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #040d1a;
    border-top: 0.5px solid rgba(255,255,255,0.05);
    padding: 56px 0 32px;
  }
  .container { max-width: 1100px; margin: 0 auto; padding: 0 32px; }

  .footer-inner {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 40px;
    margin-bottom: 48px;
  }

  .footer-brand { display: flex; flex-direction: column; gap: 14px; }

  .footer-logo {
    display: flex;
    align-items: center;
  }

  .footer-tagline {
    font-size: 13px;
    color: rgba(255,255,255,0.3);
    line-height: 1.65;
    margin: 0;
    max-width: 260px;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: flex-end;
  }
  .footer-link {
    font-family: var(--mono);
    font-size: 12px;
    color: rgba(255,255,255,0.35);
    text-decoration: none;
    transition: color 0.2s;
    letter-spacing: 0.02em;
  }
  .footer-link:hover { color: var(--teal); }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 24px;
    border-top: 0.5px solid rgba(255,255,255,0.04);
  }
  .footer-copy {
    font-family: var(--mono);
    font-size: 11px;
    color: rgba(255,255,255,0.2);
  }
  .footer-made {
    font-family: var(--mono);
    font-size: 11px;
    color: rgba(255,255,255,0.2);
  }
  @media (max-width: 640px) {
    .footer-inner { flex-direction: column; gap: 32px; }
    .footer-nav { align-items: flex-start; flex-direction: row; flex-wrap: wrap; gap: 16px; }
    .footer-bottom { flex-direction: column; gap: 8px; align-items: flex-start; }
  }
</style>

<script>
  import gsap from 'gsap';
  gsap.to('#footerHeart', {
    scale: 1.3,
    duration: 0.5,
    ease: 'power1.inOut',
    repeat: -1,
    yoyo: true,
    transformOrigin: '50% 50%',
  });
</script>
