---
---
<div class="problem-strip">
  <div class="problem-inner">
    <div class="friction-card before">
      <div class="fc-head">
        <span class="fc-dot red"></span>
        Before
      </div>
      <div class="fc-body">
        <s>30 min setup</s> · <s>Broken envs</s> · <s>Lost before slide 1</s>
      </div>
    </div>

    <!-- Pixel arrow (canvas, matches reference) -->
    <div class="friction-arrow">
      <canvas id="pxArrowCanvas"></canvas>
    </div>

    <div class="friction-card after">
      <div class="fc-head">
        <span class="fc-dot green"></span>
        With Worky
      </div>
      <div class="fc-body">
        One file, zero friction, everyone follows along.
      </div>
    </div>
  </div>
</div>

<style>
  .problem-strip {
    padding: 40px 0;
    background: linear-gradient(180deg, rgba(7,17,34,0) 0%, rgba(0,194,160,0.02) 50%, rgba(7,17,34,0) 100%);
    position: relative;
    z-index: 10;
  }
  .problem-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
  }
  .friction-card {
    flex: 1;
    background: var(--surface);
    border: 0.5px solid rgba(255,255,255,0.05);
    border-radius: 12px;
    padding: 24px 28px;
    transition: all 0.4s cubic-bezier(0.175,0.885,0.32,1.275);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .friction-card.before {
    border-color: rgba(255,87,87,0.15);
    background: linear-gradient(180deg, rgba(255,87,87,0.03), var(--surface) 40%);
    opacity: 0.85;
  }
  .friction-card.before:hover { opacity: 1; transform: translateY(-2px); border-color: rgba(255,87,87,0.3); }
  .friction-card.after {
    border-color: rgba(0,194,160,0.3);
    background: linear-gradient(180deg, rgba(0,194,160,0.06), var(--surface) 60%);
    box-shadow: 0 8px 24px rgba(0,0,0,0.2);
  }
  .friction-card.after:hover { transform: translateY(-4px) scale(1.02); border-color: var(--teal); box-shadow: 0 16px 40px rgba(0,194,160,0.12); }
  .friction-card.after .fc-body { color: rgba(255,255,255,0.95); font-weight: 500; }

  .fc-head {
    font-size: 13px;
    font-weight: 600;
    color: rgba(255,255,255,0.88);
    display: flex;
    align-items: center;
    gap: 8px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .fc-dot { width: 8px; height: 8px; border-radius: 50%; }
  .fc-dot.red { background: #FF5757; box-shadow: 0 0 8px rgba(255,87,87,0.4); }
  .fc-dot.green { background: var(--teal); animation: pulseTeal 2s infinite; }
  .fc-body { font-size: 14px; color: rgba(255,255,255,0.4); line-height: 1.6; }
  .fc-body s { text-decoration-color: rgba(255,255,255,0.2); }

  .friction-arrow { display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  #pxArrowCanvas { display: block; image-rendering: pixelated; }

  @media (max-width: 768px) {
    .problem-inner { flex-direction: column; }
    .friction-arrow { transform: rotate(90deg); margin: 8px 0; }
  }
</style>

<script>
  const canvas = document.getElementById('pxArrowCanvas') as HTMLCanvasElement | null;
  if (canvas) {
    const S = 5;      // pixel size
    const G = 2;      // gap
    const PAD = 10;   // padding for glow not to clip
    const COLS = 9;
    const ROWS = 7;
    const W = COLS * (S + G) - G;
    const H = ROWS * (S + G) - G;
    canvas.width  = W + PAD * 2;
    canvas.height = H + PAD * 2;
    const ctx = canvas.getContext('2d')!;

    // 9×7 arrow pointing right: horizontal bar row 3 + diagonal arrowhead
    const arrowPixels = new Set([
      '0,3','1,3','2,3','3,3','4,3','5,3','6,3','7,3','8,3',
      '6,0','7,1','8,2',
      '8,4','7,5','6,6',
    ]);

    const ECHO_DUR = 400;
    const state: Record<number, { bright: number; echo: number }> = {};
    for (let c = 0; c < COLS; c++) state[c] = { bright: 0, echo: 0 };

    function draw(ts: number) {
      ctx.clearRect(0, 0, canvas!.width, canvas!.height);
      for (let row = 0; row < ROWS; row++) {
        for (let col = 0; col < COLS; col++) {
          if (!arrowPixels.has(`${col},${row}`)) continue;
          const s = state[col];
          const echoFade = s.echo > 0 ? Math.max(0, 1 - (ts - s.echo) / ECHO_DUR) : 0;
          const bright = Math.max(s.bright, echoFade * 0.7);
          if (bright < 0.01) continue;
          const x = PAD + col * (S + G);
          const y = PAD + row * (S + G);
          ctx.fillStyle = `rgba(0,194,160,${(bright * 0.95).toFixed(3)})`;
          ctx.shadowColor = `rgba(0,194,160,${(bright * 0.9).toFixed(2)})`;
          ctx.shadowBlur = 8;
          ctx.beginPath();
          ctx.roundRect(x, y, S, S, 1);
          ctx.fill();
          ctx.shadowBlur = 0;
        }
      }
      requestAnimationFrame(draw);
    }
    requestAnimationFrame(draw);

    // Sweep: illuminate each column left→right then echo-fade
    function sweep() {
      let col = 0;
      const tick = setInterval(() => {
        if (col >= COLS) { clearInterval(tick); return; }
        const s = state[col];
        s.bright = 1;
        s.echo = 0;
        setTimeout(() => {
          s.bright = 0;
          s.echo = performance.now();
          setTimeout(() => { s.echo = 0; }, ECHO_DUR + 50);
        }, 110);
        col++;
      }, 65);
    }

    sweep();
    setInterval(sweep, 2000);
  }
</script>
