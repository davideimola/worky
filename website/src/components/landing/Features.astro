---
<section class="features-section" id="features">
  <div class="container">
    <div class="reveal">
      <div class="sec-label">For creators</div>
      <h2 class="sec-title">Built for developer educators.</h2>
      <p class="sec-sub">Every decision in Worky is made to reduce friction between you and your participants. You teach, it handles the rest.</p>
    </div>
    <div class="features-grid">
      {features.map((feat, i) => (
        <div class={`feat-card reveal ${i === 0 ? 'd1' : i === 1 ? 'd2' : 'd3'}`}>
          <div class="feat-icon" set:html={feat.icon} />
          <h3 class="feat-title">{feat.title}</h3>
          <p class="feat-desc">{feat.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features-section { background: #0E1F3A; padding: 140px 0; }
  .container { max-width: 1100px; margin: 0 auto; padding: 0 32px; }

  .sec-label {
    font-family: var(--mono); font-size: 11px; font-weight: 500; color: var(--teal);
    letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 14px;
    display: flex; align-items: center; gap: 10px;
  }
  .sec-label::before { content: ''; display: block; width: 16px; height: 1px; background: var(--teal); }
  .sec-title { font-size: clamp(26px, 2.8vw, 38px); font-weight: 600; letter-spacing: -0.02em; line-height: 1.15; color: rgba(255,255,255,0.92); margin: 0 0 14px; }
  .sec-sub { font-size: 17px; color: var(--slate); line-height: 1.65; max-width: 520px; margin: 0; }

  .features-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 14px; margin-top: 52px; }

  .feat-card {
    background: #112035;
    border: 0.5px solid rgba(255,255,255,0.07);
    border-radius: 12px;
    padding: 26px 26px 30px;
    transition: all 0.4s cubic-bezier(0.175,0.885,0.32,1.275);
    cursor: default;
  }
  .feat-card:hover {
    border-color: rgba(0,194,160,0.45);
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 12px 30px rgba(0,0,0,0.5), 0 0 0 1px rgba(0,194,160,0.1) inset;
  }
  .feat-card:hover .feat-icon { background: rgba(0,194,160,0.18); }
  .feat-card:hover .feat-icon :global(svg rect) { animation: pixelOn 0.42s ease-out both; }
  .feat-card:hover .feat-icon :global(svg rect:nth-child(1))  { animation-delay: 0ms; }
  .feat-card:hover .feat-icon :global(svg rect:nth-child(2))  { animation-delay: 25ms; }
  .feat-card:hover .feat-icon :global(svg rect:nth-child(3))  { animation-delay: 50ms; }
  .feat-card:hover .feat-icon :global(svg rect:nth-child(4))  { animation-delay: 75ms; }
  .feat-card:hover .feat-icon :global(svg rect:nth-child(5))  { animation-delay: 100ms; }
  .feat-card:hover .feat-icon :global(svg rect:nth-child(6))  { animation-delay: 125ms; }
  .feat-card:hover .feat-icon :global(svg rect:nth-child(7))  { animation-delay: 150ms; }
  .feat-card:hover .feat-icon :global(svg rect:nth-child(8))  { animation-delay: 175ms; }
  .feat-card:hover .feat-icon :global(svg rect:nth-child(9))  { animation-delay: 200ms; }
  .feat-card:hover .feat-icon :global(svg rect:nth-child(10)) { animation-delay: 225ms; }
  .feat-card:hover .feat-icon :global(svg rect:nth-child(11)) { animation-delay: 250ms; }
  .feat-card:hover .feat-icon :global(svg rect:nth-child(12)) { animation-delay: 275ms; }
  .feat-card:hover .feat-icon :global(svg rect:nth-child(13)) { animation-delay: 300ms; }
  .feat-card:hover .feat-icon :global(svg rect:nth-child(14)) { animation-delay: 325ms; }

  .feat-icon {
    width: 68px; height: 68px;
    background: rgba(255,255,255,0.06);
    border-radius: 14px;
    margin-bottom: 24px;
    display: flex; align-items: center; justify-content: center;
    padding: 13px;
    transition: background 0.25s ease;
  }
  .feat-icon :global(svg) { width: 100%; height: 100%; }
  .feat-title { font-size: 15px; font-weight: 600; letter-spacing: -0.01em; color: rgba(255,255,255,0.90); margin: 0 0 8px; }
  .feat-desc { font-size: 14px; color: var(--slate); line-height: 1.65; margin: 0; }

  @media (max-width: 768px) { .features-grid { grid-template-columns: 1fr; } }
</style>
